{
  "name": "deepseek-chat",
  "title": "DeepSeek Chat",
  "description": "调用 DeepSeek API 进行智能问答",
  "icon": "icon.png",
  "author": "valley",
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Ask DeepSeek",
      "description": "向 DeepSeek 提问",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "apiKey",
      "title": "DeepSeek API Key",
      "description": "你的 DeepSeek API Key",
      "type": "password",
      "required": true
    },
    {
      "name": "model",
      "title": "模型选择",
      "description": "选择使用的 DeepSeek 模型",
      "type": "dropdown",
      "required": true,
      "data": [
        {
          "title": "DeepSeek Chat (V3)",
          "value": "deepseek-chat"
        },
        {
          "title": "DeepSeek Reasoner (R1)",
          "value": "deepseek-reasoner"
        }
      ],
      "default": "deepseek-chat"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "20.8.10",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "19.0.10",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "@types/react": "19.0.10"
  },
  "scripts": {
    "build": "ray build --skip-types -e dist -o dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
